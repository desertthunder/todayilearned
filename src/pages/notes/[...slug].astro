---
import type { CollectionEntry } from "astro:content";
import EntryMeta from "../../components/EntryMeta.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { renderTilMarkdown } from "../../lib/markdown";
import { dateFromId, excerptFor, formatDate, getNotes, hrefFor } from "../../lib/til";

export async function getStaticPaths() {
	const entries = await getNotes();
	return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

type Props = { entry: CollectionEntry<"til"> };

const { entry } = Astro.props;
const date = dateFromId(entry.id)!;
const content = renderTilMarkdown(entry.body ?? "", entry.id);
const related = (await getNotes())
	.filter((candidate) => {
		if (candidate.id === entry.id) return false;
		return candidate.data.tags.some((tag) => entry.data.tags.includes(tag));
	})
	.slice(0, 3);
---

<BaseLayout title={entry.data.title} description={excerptFor(entry)} currentId={entry.id}>
	<article class="til-entry">
		<a class="back-link" href="/#latest"><span aria-hidden="true">←</span> Back to the log</a>
		<header class="til-entry__header">
			<p class="til-entry__meta">
				<time datetime={date.toISOString()}>{formatDate(date)}</time>
				{
					entry.data.tags.length > 0 && (
						<>
							<span aria-hidden="true"> / </span>
							{entry.data.tags.join(", ")}
						</>
					)
				}
			</p>
			<h1>{entry.data.title}</h1>
		</header>
		<div class="til-entry__content" set:html={content} />

		<footer class="entry-footer">
			<EntryMeta entry={entry} />
			{
				related.length > 0 && (
					<section class="related-notes" aria-labelledby="related-title">
						<p class="eyebrow" id="related-title">
							Nearby notes
						</p>
						<ul>
							{related.map((candidate) => (
								<li>
									<a href={hrefFor(candidate)}>{candidate.data.title}</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</footer>
	</article>
</BaseLayout>

<style is:global>
	.til-entry {
		max-width: var(--reading-width);
		min-width: 0;
	}

	.back-link {
		display: inline-flex;
		gap: var(--space-2);
		margin-bottom: var(--space-10);
		color: var(--color-muted);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 500;
		text-decoration-style: dashed;
	}

	.til-entry__header {
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--color-border);
	}

	.til-entry__meta {
		color: var(--color-muted);
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.03em;
		line-height: 1.4;
	}

	.til-entry__header h1 {
		margin-top: var(--space-2);
		font-size: clamp(2.4rem, 5vw, 3.9rem);
		font-weight: 400;
		letter-spacing: -0.05em;
		line-height: 1;
	}

	.til-entry__content {
		margin-top: var(--space-8);
		font-size: clamp(var(--text-md), 2vw, 1.28rem);
		line-height: 1.76;
	}

	.til-entry__content > * + * {
		margin-top: var(--space-6);
	}

	.til-entry__content h2,
	.til-entry__content h3 {
		margin-top: var(--space-12);
		letter-spacing: -0.025em;
	}

	.til-entry__content h2 {
		font-size: var(--text-xl);
	}

	.til-entry__content h3 {
		font-size: var(--text-lg);
	}

	.til-entry__content :is(ul, ol) {
		padding-left: 1.3em;
	}

	.til-entry__content li + li {
		margin-top: var(--space-2);
	}

	.til-entry__content blockquote {
		padding-left: var(--space-5);
		border-left: 2px solid var(--color-accent);
		color: var(--color-muted);
		font-style: italic;
	}

	.til-entry__content pre {
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-code-bg);
		font-size: 0.84em;
		line-height: 1.65;
		overflow-x: auto;
	}

	.til-entry__content pre code {
		padding: 0;
		background: transparent;
	}

	.til-entry__content img {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
	}

	.til-entry__content a {
		text-decoration-style: dotted;
	}

	.til-entry__content sup a {
		padding-inline: 0.13em;
		color: var(--color-accent);
		font-family: var(--font-sans);
		font-size: 0.67em;
		font-weight: 600;
		text-decoration: none;
	}

	.til-entry__content [data-footnotes] {
		font-size: var(--text-sm);
		line-height: 1.55;
	}

	.entry-footer {
		display: grid;
		gap: var(--space-8);
		margin-top: var(--space-12);
		padding-top: var(--space-6);
		border-top: 1px solid var(--color-border);
	}

	.related-notes {
		padding-top: var(--space-6);
		border-top: 1px solid var(--color-border);
	}

	.related-notes ul {
		display: grid;
		gap: var(--space-3);
		margin-top: var(--space-4);
		list-style: none;
		font-family: var(--font-serif);
		font-size: var(--text-md);
		line-height: 1.35;
	}

	.related-notes a {
		text-decoration-style: dotted;
	}
</style>

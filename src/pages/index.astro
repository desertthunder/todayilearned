---
import BaseLayout from "../layouts/BaseLayout.astro";
import TilList from "../components/TilList.astro";
import { getNotes } from "../lib/til";

const entries = await getNotes();
---

<BaseLayout>
	<div class="archive-page">
		<header class="archive-page__header">
			<h1>Recent Notes</h1>
			<div class="archive-page__lede">
				<p>
					TIL - <a href="https://www.reddit.com/r/todayilearned/">Today I Learned</a>
				</p>
				<p>Small, short, daily notes.</p>
				<span>
					total: {entries.length}&nbsp;{entries.length === 1 ? "note" : "notes"}
				</span>
			</div>
		</header>

		<section class="archive-section" id="latest" aria-label="Recent notes">
			<TilList entries={entries} />
		</section>
	</div>
</BaseLayout>

<style>
	.archive-page {
		max-width: 80ch;
	}

	.archive-page__header {
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-border);
	}

	.archive-page__header h1 {
		margin-top: var(--space-3);
		font-size: clamp(2.4rem, 5vw, 3.6rem);
		font-weight: 500;
		letter-spacing: -0.025em;
		line-height: 1;
	}

	.archive-page__lede {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		margin-top: var(--space-4);
		color: var(--color-muted);
		font-size: var(--text-base);
		line-height: 1.55;
	}

	.archive-section {
		padding-top: var(--space-8);
	}
</style>

---
import { META } from "../lib/meta";
---

<footer class="site-footer">
	<a href={META.REPO_URL} rel="noreferrer">Source</a>
	<a href={META.REPO_URL} rel="noreferrer">RSS</a>
	<a href={META.REPO_URL} rel="noreferrer">Sitemap</a>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		padding: var(--space-4);
		border-top: 1px solid var(--color-border);
		color: var(--color-muted);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		display: inline-flex;
		gap: var(--space-4);
	}

	.site-footer p + a {
		display: inline-block;
		margin-top: var(--space-2);
	}

	.site-footer a {
		color: var(--color-text);
		font-weight: 500;
	}
</style>

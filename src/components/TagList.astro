---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="Topics">
			{tags.map((tag) => (
				<li class="tag-list__item">{tag}</li>
			))}
		</ul>
	)
}

<style>
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0;
		margin-top: var(--space-3);
		list-style: none;
		color: var(--color-muted);
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.03em;
	}

	.tag-list__item {
		line-height: 1.4;
	}

	.tag-list__item + .tag-list__item::before {
		margin-inline: 0.35rem;
		color: var(--color-border);
		content: "/";
	}
</style>
